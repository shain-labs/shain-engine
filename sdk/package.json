{
  "name": "@shain/sdk",
  "version": "0.4.1",
  "description": "TypeScript client SDK for the Shain holder-gated private session program on Solana.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.js",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "lint": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "solana",
    "anchor",
    "web3",
    "privacy",
    "shain",
    "anti-sniper",
    "holder-gating",
    "session",
    "spl-token"
  ],
  "author": {
    "name": "Shain core",
    "url": "https://shain.fun"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shain-labs/shain-engine.git",
    "directory": "sdk"
  },
  "homepage": "https://shain.fun",
  "bugs": {
    "url": "https://github.com/shain-labs/shain-engine/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "sideEffects": false,
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/spl-token": "^0.4.8",
    "@solana/web3.js": "^1.95.3",
    "bn.js": "^5.2.1"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.5",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.9",
    "jest": "^29.7.0",
    "prettier": "^3.3.2",
    "rimraf": "^5.0.7",
    "ts-jest": "^29.1.5",
    "typescript": "^5.5.3"
  }
}
